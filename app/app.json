{
  "expo": {
    "name": "Lions Club Ahmedabad Host",
    "slug": "lionsclub-ahmedabad",
    "version": "0.1.0",
    "scheme": "lionsclub",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#001F45"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lionsclub.ahmedabad",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "Receive event reminders and announcements."
      }
    },
    "android": {
      "package": "com.lionsclub.ahmedabad",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#001F45"
      },
      "permissions": [
        "NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#FFD100"
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "https://8d81-2405-201-202b-b8c5-f907-6bd9-4461-8b78.ngrok-free.app",
      "eas": {
        "projectId": "f9f67e3e-62ce-4222-ab83-2cb25dffb4ef"
      }
    },
    "owner": "freeza_goku"
  }
}
