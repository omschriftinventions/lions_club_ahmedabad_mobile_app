{
  "expo": {
    "name": "Lions Club Ahmedabad Host",
    "slug": "lionsclub-ahmedabad",
    "version": "0.2.0",
    "scheme": "lionsclub",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#001F45"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lionsclub.ahmedabad",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Select photos to upload to your profile and the club gallery.",
        "NSCameraUsageDescription": "Take photos for your profile and the club gallery.",
        "NSMicrophoneUsageDescription": "Required to record meeting audio for AI transcription and summaries.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.lionsclub.ahmedabad",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#001F45"
      },
      "permissions": [
        "NOTIFICATIONS",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#FFD100"
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Required to record meeting audio for AI transcription and summaries."
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "https://api.lionsclubofahmedabadhost.com",
      "eas": {
        "projectId": "f9f67e3e-62ce-4222-ab83-2cb25dffb4ef"
      }
    },
    "owner": "freeza_goku",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/f9f67e3e-62ce-4222-ab83-2cb25dffb4ef"
    }
  }
}
