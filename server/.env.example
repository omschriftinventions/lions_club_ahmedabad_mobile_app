# Server runtime config. Copy to .env in production / local.
NODE_ENV=development
PORT=4000

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=lions
DB_PASSWORD=lionspass
DB_NAME=lionsclub
DB_CONNECTION_LIMIT=10

# JWT
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# OTP
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_DEV_LOG=true        # Print OTP to server logs in dev (no SMS gateway)
DEV_BYPASS_OTP=false    # DEV ONLY: accept ANY 6-digit code. Never enable in prod.

# SMS gateway (leave blank in dev — OTP printed to logs)
SMS_PROVIDER=
SMS_API_KEY=
SMS_SENDER_ID=LIONSC

# Expo push
EXPO_ACCESS_TOKEN=

# CORS
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# Super admin fixed password (re-applied on every server boot)
SUPER_ADMIN_PASSWORD=Omsinv@8786

# Photo uploads (direct upload to server disk)
# UPLOADS_DIR=        # absolute dir; default <cwd>/uploads/photos
# PUBLIC_BASE_URL=    # public base for photo URLs; if empty, derived from request host (set this only if the server is reached via a different public URL than the API host)
